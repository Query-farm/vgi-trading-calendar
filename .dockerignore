# Keep the Docker build context small and deterministic. The image installs the
# package from source (`pip install '.[serve]'`) and copies the repo-root entry
# script, so it only needs the package, the entry script, the entrypoint, and
# packaging metadata — not local dev/test artifacts.
*

# Re-include exactly what the build needs.
!vgi_trading_calendar/
!trading_calendar_worker.py
!pyproject.toml
!README.md
!LICENSE
!docker-entrypoint.sh

# Even within the re-included tree, never ship caches.
**/__pycache__/
**/*.pyc
